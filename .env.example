# Copy this file to .env.local and fill in real values (from the team password manager).
# .env.local is gitignored — never commit real secrets. All keys are EXPO_PUBLIC_*
# so they are readable by the client bundle.

# Supabase project URL, e.g. https://<ref>.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (publishable) key
EXPO_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME

# App-level shared secret used by client helpers
EXPO_PUBLIC_APP_SECRET=REPLACE_ME

# Google Maps / Routes API key (also wired into iOS & Android native config)
EXPO_PUBLIC_GOOGLE_MAPS_KEY=REPLACE_ME
